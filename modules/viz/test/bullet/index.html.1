icron; (14) ό&pi;&omicron;&upsilon; &tau;&omicron; &mu;&omicron;&nu;&omicron;&pi;ά&tau;&iota; &alpha;&lambda;&lambda;ά&zeta;&epsilon;&iota; &kappa;&alpha;&tau;&epsilon;ύ&theta;&upsilon;&nu;&sigma;&eta; &kappa;&alpha;&iota; &alpha;&rho;&chi;ί&zeta;&epsilon;&iota; &nu;&alpha; &kappa;&iota;&nu;&epsilon;ί&tau;&alpha;&iota; &Delta;. &Tau;&epsilon;&lambda;&iota;&kappa;ά &kappa;&alpha;&tau;&eta;&phi;&omicron;&rho;ί&zeta;&epsilon;&iota; &sigma;&epsilon; &rho;&epsilon;&mu;&alpha;&tau;&iota;ά &kappa;&alpha;&iota; &beta;&gamma;&alpha;ί&nu;&epsilon;&iota; &pi;ά&lambda;&iota; &sigma;&epsilon; &delta;&alpha;&sigma;&iota;&kappa;ό &delta;&rho;ό&mu;&omicron; (15). &Tau;&omicron; &epsilon;&pi;ό&mu;&epsilon;&nu;&omicron; &sigma;&kappa;έ&lambda;&omicron;&sigmaf; έ&chi;&epsilon;&iota; &chi;&alpha;&lambda;ά&sigma;&epsilon;&iota; &gamma;&iota;&alpha; &alpha;&upsilon;&tau;ό &alpha;&kappa;&omicron;&lambda;&omicron;&upsilon;&theta;&omicron;ύ&mu;&epsilon; &tau;&omicron;&nu; &delta;&rho;ό&mu;&omicron; &mu;έ&chi;&rho;&iota; &nu;&alpha; &kappa;&alpha;&beta;&alpha;&lambda;ή&sigma;&omicron;&upsilon;&mu;&epsilon; &rho;ά&chi;&eta; &kappa;&alpha;&iota; &sigma;&tau;&eta;&nu; &sigma;&upsilon;&nu;έ&chi;&epsilon;&iota;&alpha; &mu;&pi;&alpha;ί&nu;&omicron;&upsilon;&mu;&epsilon; (16) &pi;ά&lambda;&iota; &sigma;&tau;&omicron; &mu;&omicron;&nu;&omicron;&pi;ά&tau;&iota; &delta;&epsilon;&xi;&iota;ά &alpha;&pi;ό &xi;ύ&lambda;&iota;&nu;&eta; &kappa;&alpha;&tau;&alpha;&sigma;&kappa;&epsilon;&upsilon;ή. &Tau;ώ&rho;&alpha; &kappa;&iota;&nu;&epsilon;ί&tau;&alpha;&iota; &pi;ά&nu;&omega; &sigma;&epsilon; &rho;ά&chi;&eta; &omicron;&mu;&alpha;&lambda;ά &kappa;&alpha;&iota; &tau;&epsilon;&rho;&mu;&alpha;&tau;ί&zeta;&epsilon;&iota; &sigma;&tau;&eta;&nu; &kappa;&omicron;ί&tau;&eta; &rho;&epsilon;&mu;&alpha;&tau;&iota;ά&sigmaf; (18). &Pi;&epsilon;&rho;&nu;ά&mu;&epsilon; &alpha;&pi;έ&nu;&alpha;&nu;&tau;&iota; &kappa;&alpha;&iota; &kappa;&iota;&nu;&omicron;ύ&mu;&alpha;&sigma;&tau;&epsilon; &delta;&epsilon;&xi;&iota;ά &alpha;&