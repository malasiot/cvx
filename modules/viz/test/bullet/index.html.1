<p class="western" lang="el-GR" style="line-height: 150%;" align="justify">&nbsp;</p>
<p class="western" lang="el-GR" style="line-height: 150%;" align="justify">&Alpha;&upsilon;&tau;ή &epsilon;ί&nu;&alpha;&iota; ί&sigma;&omega;&sigmaf; &eta; &sigma;&upsilon;&nu;&tau;&omicron;&mu;ό&tau;&epsilon;&rho;&eta; &delta;&iota;&alpha;&delta;&rho;&omicron;&mu;ή &gamma;&iota;&alpha; &tau;&eta;&nu; &Mu;. &Beta;&alpha;&tau;&omicron;&pi;&epsilon;&delta;ί&omicron;&upsilon; &alpha;&pi;ό &tau;&alpha; &delta;&upsilon;&tau;&iota;&kappa;ά &sigma;&tau;&alpha; &alpha;&nu;&alpha;&tau;&omicron;&lambda;&iota;&kappa;ά. &Tau;&omicron; &pi;&rho;ώ&tau;&omicron; &sigma;&kappa;έ&lambda;&omicron;&sigmaf; &epsilon;ί&nu;&alpha;&iota; &sigma;&upsilon;&nu;&delta;&upsilon;&alpha;&sigma;&mu;ό&sigmaf; &alpha;&pi;ό &tau;&omicron; &pi;&alpha;&lambda;&iota;ό &mu;&omicron;&nu;&omicron;&pi;ά&tau;&iota; &kappa;&alpha;&iota; &delta;&alpha;&sigma;&iota;&kappa;&omicron;ύ&sigmaf; &delta;&rho;ό&mu;&omicron;&upsilon;&sigmaf; &kappa;&alpha;&iota; &delta;&epsilon;&nu; έ&chi;&epsilon;&iota; &sigma;ή&mu;&alpha;&nu;&sigma;&eta;. &Tau;&omicron; &delta;&epsilon;ύ&tau;&epsilon;&rho;&omicron;&sigmaf; &sigma;&kappa;έ&lambda;&omicron;&sigmaf;, &alpha;&pi;ό &tau;&eta;&nu; &kappa;&epsilon;&nu;&tau;&rho;&iota;&kappa;ή &rho;ά&chi;&eta; &mu;έ&chi;&rho;&iota; &tau;&eta;&nu; &Mu;. &Beta;&alpha;&tau;&omicron;&pi;&epsilon;&delta;ί&omicron;&upsilon; &epsilon;ί&nu;&alpha;&iota; &kappa;&upsilon;&rho;ί&omega;&sigmaf; &mu;&omicron;&nu;&omicron;&pi;ά&tau;&iota; &kappa;&alpha;&iota; έ&chi;&epsilon;&iota; &sigma;&eta;&mu;&alpha;&tau;&omicron;&delta;&omicron;&tau;&eta;&theta;&epsilon;ί &pi;&rho;ό&sigma;&phi;&alpha;&tau;&alpha;.</p>
<p class="western" lang="el-GR" style="line-height: 150%;" align="justify">&Alpha;&pi;ό &tau;&eta;&nu; &epsilon;ί&sigma;&omicron;&delta;&omicron; &tau;&eta;&sigmaf; &mu;&omicron;&nu;ή&sigmaf; (1) &alpha;&nu;&eta;&phi;&omicron;&rho;ί&zeta;&omicron;&upsilon;&mu;&epsilon; &sigma;&tau;&omicron; &kappa;&alpha;&lambda;&nu;&tau;&epsilon;&rho;ί&mu;&iota; &alpha;&rho;&iota;&sigma;&tau;&epsilon;&rho;ά &kappa;&alpha;&iota; &mu;ώ&lambda;&iota;&sigmaf; &pi;&epsilon;&rho;ά&sigma;&omicron;&upsilon;&mu;&epsilon; &tau;&omicron; &mu;&epsilon;&gamma;ά&lambda;&omicron; &kappa;&tau;ή&rho;&iota;&omicron; &tau;&omicron;&upsilon; &xi;&upsilon;&lambda;&omicron;&upsilon;&rho;&gamma;&epsilon;ί&omicron;&upsilon; &sigma;&tau;&rho;ί&beta;&omicron;&upsilon;&mu;&epsilon; &alpha;&pi;ό&tau;&omicron;&mu;&alpha; &alpha;&rho;&iota;&sigma;&tau;&epsilon;&rho;ά &pi;ά&lambda;&iota; &sigma;&epsilon; &kappa;&alpha;&lambda;&nu;&tau;&epsilon;&rho;ί&mu;&iota;, &pi;&epsilon;&rho;&nu;ά&mu;&epsilon; &sigma;&upsilon;&rho;&mu;ά&tau;&iota;&nu;&eta; &pi;ό&rho;&tau;&alpha; &kappa;&alpha;&iota; &alpha;&nu;&eta;&phi;&omicron;&rho;ί&zeta;&omicron;&upsilon;&mu;&epsilon; &mu;&epsilon; &zeta;&iota;&kappa;-&zeta;&alpha;&kappa; &sigma;&epsilon; &phi;&alpha;&rho;&delta;ύ &chi;&omicron;&rho;&tau;&alpha;&rho;&iota;&alpha;&sigma;&mu;έ&nu;&omicron; &mu;&omicron;&nu;&omicron;&pi;ά&tau;&iota;. &Alpha;&upsilon;&tau;ό &kappa;&alpha;&tau;&alpha;&lambda;ή&gamma;&epsilon;&iota; &tau;&epsilon;&lambda;&iota;&kappa;ά &pi;ά&nu;&omega; &sigma;&epsilon; &rho;ά&chi;&eta; ό&pi;&omicron;&upsilon; &upsilon;&pi;ά&rho;&chi;&epsilon;&iota; &delta;&epsilon;&xi;&alpha;&mu;&epsilon;&nu;ή (2). &Epsilon;&delta;ώ &kappa;&alpha;&tau;&alpha;&lambda;ή&gamma;&epsilon;&iota; &kappa;&alpha;&iota; &tau;&rho;&alpha;&kappa;&tau;&epsilon;&rho;ό&delta;&rho;&omicron;&mu;&omicron;&sigmaf;. &Tau;&omicron; &epsilon;&pi;ό&mu;&epsilon;&nu;&omicron; &sigma;&kappa;έ&lambda;&omicron;&sigmaf; &tau;&omicron;&upsilon; &mu;&omicron;&nu;&omicron;&pi;&alpha;&tau;&iota;&omicron;ύ έ&chi;&epsilon;&iota; &kappa;&lambda;&epsilon;ί&sigma;&epsilon;&iota; &kappa;&alpha;&iota; &gamma;&iota;&alpha; &alpha;&upsilon;&tau;ό &alpha;&kappa;&omicron;&lambda;&omicron;&upsilon;&theta;&omicron;ύ&mu;&epsilon; &tau;&omicron;&nu; &tau;&rho;&alpha;&kappa;&tau;&epsilon;&rho;ό&delta;&rho;&omicron;&mu;&omicron; &kappa;&alpha;&iota; &sigma;&tau;&omicron; &sigma;&eta;&mu;&epsilon;ί&omicron; &pi;&omicron;&upsilon; &sigma;&tau;&rho;ί&beta;&epsilon;&iota; &alpha;&rho;&iota;&sigma;&tau;&epsilon;&rho;ά &tau;&omicron;&nu; &alpha;&phi;ή&nu;&omicron;&upsilon;&mu;&epsilon; &kappa;&alpha;&iota; &mu;&pi;&alpha;ί&nu;&omicron;&upsilon;&mu;&epsilon; &pi;ά&lambda;&iota; &sigma;&tau;&omicron;&nu; &mu;&omicron;&nu;&omicron;&pi;ά&tau;&iota; (3). &Alpha;&upsilon;&tau;ό &kappa;&alpha;&tau;&eta;&phi;&omicron;&rho;ί&zeta;&epsilon;&iota; &sigma;&epsilon; &rho;&epsilon;&mu;&alpha;&tau;&iota;ά &kappa;&alpha;&iota; &alpha;&rho;&chi;ί&zeta;&epsilon;&iota; &nu;&alpha; &alpha;&nu;&eta;&phi;&omicron;&rho;ί&zeta;&epsilon;&iota; &kappa;&alpha;&iota; &pi;ά&lambda;&iota; &Nu; &epsilon;&nu;ώ &sigma;&tau;&eta;&nu; &sigma;&upsilon;&nu;έ&chi;&epsilon;&iota;&alpha; &sigma;&tau;&rho;έ&phi;&epsilon;&tau;&alpha;&iota; &Beta; &kappa;&alpha;&iota; &kappa;&alpha;&tau;&alpha;&lambda;ή&gamma;&epsilon;&iota; &tau;&epsilon;&lambda;&iota;&kappa;ά &sigma;&tau;&eta;&nu; &kappa;&omicron;&rho;&upsilon;&phi;ή &rho;ά&chi;&eta;&sigmaf; &sigma;&epsilon; &tau;&rho;&alpha;&kappa;&tau;&epsilon;&rho;ό&delta;&rho;&omicron;&mu;&omicron; (5). &Mu;&epsilon;&tau;ά &alpha;&pi;ό 100&mu; &omicron; &delta;&rho;ό&mu;&omicron;&sigmaf; &alpha;&upsilon;&tau;ό&sigmaf; &sigma;&upsilon;&nu;&alpha;&nu;&tau;ά &phi;&alpha;&rho;&delta;ύ &delta;&alpha;&sigma;&iota;&kappa;ό &delta;&rho;ό&mu;&omicron; (6). &Tau;ώ&rho;&alpha; &alpha;&kappa;&omicron;&lambda;&omicron;&upsilon;&theta;ώ&nu;&tau;&alpha;&sigmaf; &delta;&alpha;&sigma;&iota;&kappa;&omicron;ύ&sigmaf; &delta;&rho;ό&mu;&omicron;&upsilon;&sigmaf; &phi;&tau;ά&nu;&omicron;&upsilon;&mu;&epsilon; &tau;&e